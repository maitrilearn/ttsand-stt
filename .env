# ── Groq API ──────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# ── Voice Settings ────────────────────────────────────────────────
# Indian English voices (no model files needed):
# en-IN-NeerjaExpressiveNeural  ← best for teaching (default)
# en-IN-NeerjaNeural            ← natural female
# en-IN-PrabhatNeural           ← clear male
EDGE_TTS_VOICE=en-IN-NeerjaExpressiveNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
